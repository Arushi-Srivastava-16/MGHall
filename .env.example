# CHG Framework — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Required ──────────────────────────────────────────────
# Google Gemini API key (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional ──────────────────────────────────────────────
# OpenAI API key (for GPT-4 multi-model consensus, optional)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API key (future support, optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Backend server port (default: 8000)
BACKEND_PORT=8000

# Frontend dev server port (default: 5173)
FRONTEND_PORT=5173

# Set to "production" for prod deployments
ENVIRONMENT=development
